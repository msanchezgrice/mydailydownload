# Daily AI Edge — Environment Configuration

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Model
# OpenAI options: gpt-4o-mini (cheapest), gpt-4o (better quality)
# Anthropic options: claude-3-haiku-20240307 (cheapest), claude-3-sonnet-20240229 (better)
LLM_MODEL=gpt-4o-mini

# Email (Resend)
# Get API key at https://resend.com (free tier: 3,000 emails/day)
RESEND_API_KEY=re_your-resend-key-here
FROM_EMAIL=newsletter@dailyaiedge.com
FROM_NAME=Daily AI Edge

# Database
DATABASE_PATH=./subscribers.db

# Newsletter delivery time (24-hour format, local timezone)
NEWSLETTER_TIME=07:00
